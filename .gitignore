# Python
__pycache__/
*.py[cod]

# Virtual environment
.venv/

# Runtime writable data (API keys, memory, logs) — never commit
/data/

# Personal Claude Code overrides for this project
/.claude/settings.local.json

# Stray scratch files from AI/shell runs (diff dumps, redirect mishaps) — 兜底，别再误入版本库
/_diff_*.txt
/$null
/_t_*.py
/_strip*.py

# Throwaway visual-preview render
/_preview.*

# Throwaway pre-comment-strip source backup
/_backup_pre_comment_strip/

# PyInstaller 打包产物
/build/
/dist/
